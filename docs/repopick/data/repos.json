  {
    "id": "boltdb",
    "name": "boltdb/bolt",
    "url": "https://github.com/boltdb/bolt",
    "ref": "v1.3.1",
    "language": "Go",
    "themes": [
      "databases",
      "storage"
    ],
    "difficulty": 2,
    "why": "Single-file embedded KV with a B+tree on mmap, small enough to hold in your head — the cleanest MVCC-via-COW I've read in open source. Tag v1.3.1 is the last release before archive.",
    "entry_points": [
      {
        "label": "Trace a Put through a write transaction",
        "files": [
          "db.go",
          "tx.go",
          "bucket.go",
          "node.go"
        ],
        "question": "Where does the copy-on-write actually happen, and how do in-flight readers see a consistent snapshot of the old tree while a writer is mutating pages?"
      },
      {
        "label": "Understand the freelist",
        "files": [
          "freelist.go",
          "page.go"
        ],
        "question": "How does Bolt reclaim freed pages without breaking readers that still hold pointers into the old MVCC snapshot?"
      }
    ],
    "reading": []
  },
